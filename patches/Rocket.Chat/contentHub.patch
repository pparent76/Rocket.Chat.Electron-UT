+const safeFilename = (filename: string): string => {
+  const sanitized = Array.from(filename)
+    .map((char) => {
+      if (char.charCodeAt(0) < 32 || /[<>:"/\\|?*]/.test(char)) {
+        return '_';
+      }
+
+      return char;
+    })
+    .join('')
+    .replace(/\s+/g, ' ')
+    .trim();
+
+  return sanitized || 'download';
+};
+
+const registerDownloadHandler = (session: Session): void => {
+  if (sessionsWithDownloadHandler.has(session)) {
+    return;
+  }
+
+  sessionsWithDownloadHandler.add(session);
