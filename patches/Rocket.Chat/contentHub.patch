 // Lazy default download path resolution
 let cachedDefaultDownloadPath: string | null = null;
 
 function getDefaultDownloadPath(): string {
   if (cachedDefaultDownloadPath === null) {
     try {
       cachedDefaultDownloadPath = app.getPath('downloads');
     } catch {
       cachedDefaultDownloadPath = os.tmpdir();
     }
   }
   return cachedDefaultDownloadPath;
 }
 
 function isValidDirectory(dir: string): boolean {
   try {
     return !!dir && existsSync(dir) && statSync(dir).isDirectory();
   } catch {
     return false;
   }
 }
 
+const sessionsWithDownloadHandler = new WeakSet<Session>();
+
+const safeFilename = (filename: string): string => {
+  const sanitized = Array.from(filename)
+    .map((char) => {
+      if (char.charCodeAt(0) < 32 || /[<>:"/\\|?*]/.test(char)) {
+        return '_';
+      }
+
+      return char;
+    })
+    .join('')
+    .replace(/\s+/g, ' ')
+    .trim();
+
+  return sanitized || 'download';
+};
+
+const registerDownloadHandler = (session: Session): void => {
+  if (sessionsWithDownloadHandler.has(session)) {
+    return;
+  }
+
+  sessionsWithDownloadHandler.add(session);
+
+  session.on('will-download', (_event: Event, item: DownloadItem): void => {
+    console.log(`[download] ${item.getFilename()} <- ${item.getURL()}`);
+
+    const downloadDir = getDefaultDownloadPath();
+    item.setSavePath(path.join(downloadDir, safeFilename(item.getFilename())));
+
+    item.on('done', async (_event: Event, state: string) => {
+      if (state === 'completed') {
+        await shell.openExternal(pathToFileURL(item.getSavePath()).toString());
+      }
+    });
+  });
+};
+
+const setupDownloadHandlersForAllSessions = (): void => {
+  registerDownloadHandler(electronSession.defaultSession);
+  app.on('session-created', registerDownloadHandler);
+};
+
